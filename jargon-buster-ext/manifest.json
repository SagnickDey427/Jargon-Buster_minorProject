{
  "manifest_version": 3,
  "name": "Jargon Buster MVP",
  "version": "1.0",
  "description": "Simplifies dense text.",
  "permissions": [
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}