{
  "manifest_version": 3,
  "name": "Jargon Buster MVP",
  "version": "1.0",
  "description": "Simplifies dense text.",
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}